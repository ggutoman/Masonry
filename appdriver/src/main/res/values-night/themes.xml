<?xml version="1.0" encoding="utf-8"?>

<!--colorPrimary (app bar, material button)-->
<!--colorOnPrimary (on top of color primary object by property)-->
<!--colorSecondaru (floating button)-->
<!--colorOnSecondary (on top of color secondary object by property)-->

<resources>

    <!-- APP THEME -->
    <style name="MasonryTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/material_yellow</item>
        <item name="colorOnPrimary">@color/material_black</item>
        <item name="colorSecondary">@color/material_yellow</item>
        <item name="colorOnSecondary">@color/material_black</item>
        <item name="android:windowBackground">@color/material_background</item>
        <item name="android:statusBarColor">@color/material_yellow</item>
        <item name="android:textColor">@color/material_black</item>
        <item name="android:fontFamily">@font/roboto_regular</item>
        <item name="fontFamily">@font/roboto_regular</item>
    </style>

    <!-- TEXT INPUT -->
    <style name="TextInputStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:layout_margin">2dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>

    </style>

    <style name="TextInputStyle.Edittext">
        <item name="iconStartPadding">10dp</item>
        <item name="android:drawablePadding">10dp</item>
    </style>

    <style name="TextInputStyleRounded" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:layout_margin">2dp</item>
        <item name="boxCornerRadiusBottomEnd">20dp</item>
        <item name="boxCornerRadiusBottomStart">20dp</item>
        <item name="boxCornerRadiusTopStart">20dp</item>
        <item name="boxCornerRadiusTopEnd">20dp</item>
    </style>

    <!-- TEXT AREA -->
    <style name="TextInputTextAreaStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:layout_margin">2dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="android:inputType">textMultiLine</item>
        <item name="android:overScrollMode">always</item>
        <item name="android:scrollHorizontally">false</item>
        <item name="android:lines">3</item>
        <item name="android:ellipsize">none</item>
    </style>

    <!-- TEXT AUTOFILL-->
    <style name="AutoCompleteStyleTheme">
        <item name="android:paddingTop">15dp</item>
        <item name="android:paddingBottom">15dp</item>
        <item name="android:paddingLeft">10dp</item>
        <item name="paddingStart">10dp</item>
        <item name="maxLines">1</item>
    </style>

    <!-- DROPDOWN LAYOUT-->
    <style name="CustomDropDownTilStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">2dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
    </style>

    <!-- DROPDOWN INPUT STYLE-->
    <style name="DropdownStyleTheme" parent="AutoCompleteStyleTheme">
        <item name="android:focusable">false</item>
        <item name="android:clickable">false</item>
        <item name="android:cursorVisible">false</item>
        <item name="android:inputType">none</item>
    </style>

    <!-- TEXT STYLINGS-->

    <style name="Text_Title">
        <item name="android:textSize">18sp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="Text_Header">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Text_Footer" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:gravity">center_horizontal</item>
        <item name="android:textSize">10sp</item>
    </style>

    <style name="Text_Note" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:textSize">12sp</item>
        <item name="android:padding">10dp</item>
        <item name="android:textStyle">italic</item>
        <item name="android:alpha">0.5</item>
    </style>

    <style name="Text_Link" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:gravity">start</item>
        <item name="android:textSize">12sp</item>
        <item name="android:padding">10dp</item>
        <item name="android:textStyle">italic</item>
        <item name="android:alpha">0.5</item>
    </style>

    <style name="Text_Error" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textStyle">italic</item>
        <item name="android:textColor">@color/material_error_red</item>
        <item name="android:textSize">12sp</item>
        <item name="android:padding">5dp</item>
        <item name="android:drawablePadding">10dp</item>
        <item name="android:drawableStart">@drawable/baseline_error_24</item>
        <item name="android:drawableTint">@color/material_error_red</item>
    </style>

    <!--BUTTON STYLING-->

    <style name="Material_Button" parent="Widget.MaterialComponents.Button">
        <item name="android:padding">10dp</item>
        <item name="android:textSize">13sp</item>
        <item name="backgroundTint">@color/material_button</item>
    </style>

    <style name="Material_Button_Transparent" parent="Widget.MaterialComponents.Button">
        <item name="android:padding">10dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <!--ANIMATIONS-->
    <style name="PopupAnimation">
        <item name="android:windowEnterAnimation">@anim/anim_pop_in</item>
        <item name="android:windowExitAnimation">@anim/anim_pop_out</item>
    </style>

</resources>