<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardElevation="5dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="10dp">

        <com.google.android.material.textview.MaterialTextView
            style="@style/Text_Title"
            android:id="@+id/mtv_project_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="20dp"
            android:text="N/A" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/mtv_project_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="14sp"
            android:alpha="0.7"
            android:text="N/A" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.6dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="@android:color/darker_gray" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="10dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/mcv_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="3dp"
                    app:cardUseCompatPadding="true">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="10dp">

                        <com.google.android.material.textview.MaterialTextView
                            style="@style/Text_Header"
                            android:id="@+id/mtv_transaction"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="N/A"
                            android:alpha="0.7"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintWidth_percent="0.9"/>

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/mtv_pledge_date"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Pledges as of"
                            android:alpha="0.7"
                            android:textSize="13sp"
                            app:layout_constraintTop_toBottomOf="@+id/mtv_transaction"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/btn_download"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:scaleType="fitCenter"
                            android:src="@drawable/baseline_download"
                            app:layout_constraintStart_toEndOf="@+id/mtv_transaction"
                            app:layout_constraintTop_toTopOf="@+id/mtv_transaction"
                            app:layout_constraintBottom_toBottomOf="@+id/mtv_transaction"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <View
                            android:id="@+id/view_divider"
                            android:layout_width="match_parent"
                            android:layout_height="0.6dp"
                            android:layout_marginTop="5dp"
                            android:background="@android:color/darker_gray"
                            android:layout_marginBottom="10dp"
                            app:layout_constraintTop_toBottomOf="@+id/mtv_pledge_date"/>

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/mtv_trans_stat"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="N/A"
                            android:alpha="0.7"
                            android:gravity="end"
                            android:layout_marginTop="5dp"
                            app:layout_constraintTop_toBottomOf="@+id/view_divider"
                            app:layout_constraintStart_toEndOf="@+id/mtv_trans_stat_label"
                            app:layout_constraintEnd_toEndOf="parent"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_footer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/mtv_trans_total_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Transaction"
                        android:alpha="0.5"
                        app:layout_constraintTop_toBottomOf="@+id/mtv_trans_stat"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintWidth_percent="0.5"/>

                    <com.google.android.material.textview.MaterialTextView
                        style="@style/Text_Header"
                        android:id="@+id/mtv_trans_total"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="0.00"
                        app:layout_constraintStart_toStartOf="@+id/mtv_trans_total_label"
                        app:layout_constraintTop_toBottomOf="@+id/mtv_trans_total_label"
                        app:layout_constraintEnd_toEndOf="@+id/mtv_trans_total_label"/>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/mtv_collect_total_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Collection"
                        android:alpha="0.5"
                        android:gravity="end"
                        app:layout_constraintStart_toEndOf="@+id/mtv_trans_total_label"
                        app:layout_constraintTop_toTopOf="@+id/mtv_trans_total_label"
                        app:layout_constraintBottom_toBottomOf="@+id/mtv_trans_total_label"
                        app:layout_constraintWidth_percent="0.5"/>

                    <com.google.android.material.textview.MaterialTextView
                        style="@style/Text_Header"
                        android:id="@+id/mtv_collect_total"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="0.00"
                        android:gravity="end"
                        app:layout_constraintTop_toBottomOf="@+id/mtv_collect_total_label"
                        app:layout_constraintStart_toStartOf="@+id/mtv_collect_total_label"
                        app:layout_constraintEnd_toEndOf="@+id/mtv_collect_total_label"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_no_record"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/icon_no_record"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:src="@drawable/baseline_warning"
                android:scaleType="fitCenter"
                android:alpha="0.5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintWidth_percent="0.2"
                app:layout_constraintHeight_percent="0.1"/>

            <com.google.android.material.textview.MaterialTextView
                style="@style/Text_Title"
                android:id="@+id/mtv_no_record"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15sp"
                android:text="No data found"
                android:alpha="0.5"
                app:layout_constraintTop_toBottomOf="@+id/icon_no_record"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/layout_pledges"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="10dp"
            android:visibility="gone">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pledge Details"
                android:alpha="0.7"/>

            <View
                android:id="@+id/view_details"
                android:layout_width="match_parent"
                android:layout_height="0.6dp"
                android:layout_marginTop="5dp"
                android:background="@android:color/darker_gray"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rcv_pledge_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>