<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_marginTop="10dp"
    app:cardElevation="5dp"
    app:cardUseCompatPadding="true"
    app:cardCornerRadius="10dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="5dp">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/mtv_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="N/A"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/mtv_date_pledge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="1900-00-00"
            android:alpha="0.7"
            app:layout_constraintTop_toBottomOf="@+id/mtv_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintWidth_percent="0.5"/>

        <com.google.android.material.textview.MaterialTextView
            style="@style/Text_Header"
            android:id="@+id/mtv_amt_pledge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:alpha="0.7"
            android:gravity="end"
            app:layout_constraintTop_toTopOf="@+id/mtv_date_pledge"
            app:layout_constraintBottom_toBottomOf="@+id/mtv_date_pledge"
            app:layout_constraintStart_toEndOf="@+id/mtv_date_pledge"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.5"/>

        <View
            android:id="@+id/view_payment"
            android:layout_width="match_parent"
            android:layout_height="0.6dp"
            android:layout_marginTop="10dp"
            android:background="@android:color/darker_gray"
            app:layout_constraintTop_toBottomOf="@+id/mtv_date_pledge"
            app:layout_constraintStart_toStartOf="@+id/mtv_date_pledge"
            app:layout_constraintEnd_toEndOf="@+id/mtv_date_pledge"/>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/mtv_or_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="OR Number:"
            android:alpha="0.7"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@+id/view_payment"
            app:layout_constraintWidth_percent="0.5"/>

        <com.google.android.material.textview.MaterialTextView
            style="@style/Text_Header"
            android:id="@+id/mtv_amtpledged"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="N/A"
            android:gravity="end"
            android:alpha="0.7"
            app:layout_constraintStart_toEndOf="@+id/mtv_or_label"
            app:layout_constraintTop_toTopOf="@+id/mtv_or_label"
            app:layout_constraintBottom_toBottomOf="@+id/mtv_or_label"
            app:layout_constraintEnd_toEndOf="parent"/>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/mtv_amtpaid_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Amount Contributed:"
            android:alpha="0.7"
            app:layout_constraintTop_toBottomOf="@+id/mtv_or_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintWidth_percent="0.5"/>

        <com.google.android.material.textview.MaterialTextView
            style="@style/Text_Header"
            android:id="@+id/mtv_amtcontri"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:gravity="end"
            android:alpha="0.7"
            app:layout_constraintStart_toEndOf="@+id/mtv_amtpaid_label"
            app:layout_constraintTop_toTopOf="@+id/mtv_amtpaid_label"
            app:layout_constraintBottom_toBottomOf="@+id/mtv_amtpaid_label"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>