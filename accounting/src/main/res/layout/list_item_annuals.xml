<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    app:cardElevation="12dp"
    app:cardCornerRadius="10dp"
    app:cardUseCompatPadding="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp">

        <com.google.android.material.textview.MaterialTextView
            style="@style/Text_Header"
            android:id="@+id/mtv_transaction"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="N/A"
            android:alpha="0.7"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintWidth_percent="0.5"/>

        <com.google.android.material.textview.MaterialTextView
            style="@style/Text_Header"
            android:id="@+id/mtv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="N/A"
            android:alpha="0.7"
            android:gravity="end"
            app:layout_constraintStart_toEndOf="@+id/mtv_transaction"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <View
            android:id="@+id/view_divider"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginVertical="10dp"
            app:layout_constraintTop_toBottomOf="@+id/mtv_transaction"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.009"
            android:background="@android:color/darker_gray" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/mtv_totaltrans_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Total Transaction:"
            android:alpha="0.7"
            app:layout_constraintTop_toBottomOf="@+id/view_divider"
            app:layout_constraintStart_toStartOf="@+id/mtv_transaction"
            app:layout_constraintEnd_toEndOf="@+id/mtv_transaction"/>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/mtv_totalcoll_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Total Collection:"
            android:alpha="0.7"
            android:gravity="end"
            app:layout_constraintTop_toBottomOf="@+id/view_divider"
            app:layout_constraintStart_toStartOf="@+id/mtv_status"
            app:layout_constraintEnd_toEndOf="@+id/mtv_status"/>

        <com.google.android.material.textview.MaterialTextView
            style="@style/Text_Header"
            android:id="@+id/mtv_totaltrans"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:alpha="0.7"
            android:textStyle="italic"
            app:layout_constraintTop_toBottomOf="@+id/mtv_totalcoll_label"
            app:layout_constraintStart_toStartOf="@+id/mtv_transaction"
            app:layout_constraintEnd_toEndOf="@+id/mtv_transaction"/>

        <com.google.android.material.textview.MaterialTextView
            style="@style/Text_Header"
            android:id="@+id/mtv_totalcoll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:alpha="0.7"
            android:gravity="end"
            android:textStyle="italic"
            app:layout_constraintTop_toBottomOf="@+id/mtv_totalcoll_label"
            app:layout_constraintStart_toStartOf="@+id/mtv_status"
            app:layout_constraintEnd_toEndOf="@+id/mtv_status"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>