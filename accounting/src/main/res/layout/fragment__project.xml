<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:elevation="10dp"
    app:cardUseCompatPadding="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.textview.MaterialTextView
            style="@style/Text_Title"
            android:id="@+id/mtv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:text="Project Entry"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.6dp"
            android:layout_marginTop="10dp"
            android:background="@android:color/darker_gray"
            android:layout_marginBottom="10dp"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@+id/layout_buttons">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardElevation="6dp"
                        app:cardUseCompatPadding="true"
                        app:cardCornerRadius="10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="5dp">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="0.6dp"
                                android:background="@android:color/darker_gray"
                                android:layout_marginBottom="10dp"/>

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Transaction Number"
                                android:layout_marginHorizontal="10dp"
                                android:layout_marginTop="15dp"/>

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Generates ID once submitted to server"
                                android:textSize="13sp"
                                android:alpha="0.7"
                                android:layout_marginHorizontal="10dp"/>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/TextInputStyle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/tie_transaction_no"
                                    style="@style/TextInputStyle.Edittext"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:enabled="false"
                                    android:inputType="none" />

                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/TextInputStyle"
                                android:id="@+id/til_dtransact"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Date Transact">

                                <com.google.android.material.textfield.TextInputEditText
                                    style="@style/TextInputStyle.Edittext"
                                    android:id="@+id/tie_dtransact"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:enabled="false"
                                    android:inputType="none"/>

                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layout_tools"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="20dp"
                        android:visibility="gone">

                        <com.google.android.material.textview.MaterialTextView
                            style="@style/Text_Header"
                            android:id="@+id/btn_download"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Download"
                            android:alpha="0.75"
                            android:textColor="?attr/colorPrimary"
                            android:gravity="start"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintWidth_percent="0.5"/>

                        <com.google.android.material.textview.MaterialTextView
                            style="@style/Text_Header"
                            android:id="@+id/btn_view"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="View Details"
                            android:alpha="0.75"
                            android:textColor="?attr/colorPrimary"
                            android:gravity="end"
                            app:layout_constraintStart_toEndOf="@+id/btn_download"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintWidth_percent="0.5"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardElevation="6dp"
                        app:cardUseCompatPadding="true"
                        app:cardCornerRadius="10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Project Details"
                                android:padding="10dp"
                                android:background="@android:color/darker_gray"/>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/CustomDropDownTilStyle"
                                android:id="@+id/til_lodge_cal"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Select Lodge Year">

                                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                    android:id="@+id/auto_lodge_cal"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"/>

                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/CustomDropDownTilStyle"
                                android:id="@+id/til_proj_type"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Select Project Type">

                                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                    android:id="@+id/auto_proj_type"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:focusable="false"
                                    android:clickable="true"/>

                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/CustomDropDownTilStyle"
                                android:id="@+id/til_status"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Select Project Status">

                                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                    android:id="@+id/auto_status"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:focusable="false"
                                    android:clickable="true"/>

                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/TextInputStyle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Name of the Project">

                                <com.google.android.material.textfield.TextInputEditText
                                    style="@style/TextInputStyle.Edittext"
                                    android:id="@+id/tie_name"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"/>

                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/TextInputStyle"
                                android:id="@+id/til_due"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Validity Date">

                                <com.google.android.material.textfield.TextInputEditText
                                    style="@style/TextInputStyle.Edittext"
                                    android:id="@+id/tie_due"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:drawableEnd="@drawable/baseline_edit_calendar_24"
                                    android:focusable="false"
                                    android:clickable="true"/>

                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/TextInputStyle"
                                android:id="@+id/til_remarks"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Remarks">

                                <com.google.android.material.textfield.TextInputEditText
                                    style="@style/TextInputTextAreaStyle"
                                    android:id="@+id/tie_remarks"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"/>

                            </com.google.android.material.textfield.TextInputLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <androidx.constraintlayout.widget.ConstraintLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="20dp">

                                    <com.google.android.material.textview.MaterialTextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:text="Members Pledge"
                                        android:background="@android:color/darker_gray"
                                        android:padding="10dp"
                                        android:layout_marginTop="20dp"
                                        app:layout_constraintStart_toStartOf="parent"
                                        app:layout_constraintEnd_toEndOf="parent"/>

                                    <ImageButton
                                        android:id="@+id/btn_add_detail"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:src="@drawable/baseline_add_circle_24"
                                        android:backgroundTint="@android:color/transparent"
                                        app:layout_constraintTop_toTopOf="parent"
                                        app:layout_constraintBottom_toBottomOf="parent"
                                        app:layout_constraintEnd_toEndOf="parent"
                                        app:tint="@color/material_pale_yellow" />


                                </androidx.constraintlayout.widget.ConstraintLayout>

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="20dp">

                                    <androidx.constraintlayout.widget.ConstraintLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="vertical"
                                        android:padding="10dp">

                                        <com.google.android.material.textview.MaterialTextView
                                            android:id="@+id/mtv_totaltrans_label"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:text="Total Pledges:"
                                            android:layout_marginTop="10dp"
                                            app:layout_constraintStart_toStartOf="parent"
                                            app:layout_constraintWidth_percent="0.5"/>

                                        <com.google.android.material.textview.MaterialTextView
                                            style="@style/Text_Header"
                                            android:id="@+id/mtv_totalpledge"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:text="0.00"
                                            android:gravity="end"
                                            app:layout_constraintTop_toTopOf="@+id/mtv_totaltrans_label"
                                            app:layout_constraintBottom_toBottomOf="@+id/mtv_totaltrans_label"
                                            app:layout_constraintStart_toEndOf="@+id/mtv_totaltrans_label"
                                            app:layout_constraintEnd_toEndOf="parent" />

                                        <com.google.android.material.textview.MaterialTextView
                                            android:id="@+id/mtv_totalcoll_label"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:text="Total Contributions:"
                                            android:layout_marginTop="10dp"
                                            app:layout_constraintTop_toBottomOf="@+id/mtv_totaltrans_label"
                                            app:layout_constraintStart_toStartOf="@+id/mtv_totaltrans_label"
                                            app:layout_constraintEnd_toEndOf="@+id/mtv_totaltrans_label"
                                            app:layout_constraintWidth_percent="0.5"/>

                                        <com.google.android.material.textview.MaterialTextView
                                            style="@style/Text_Header"
                                            android:id="@+id/mtv_totalcontri"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:text="0.00"
                                            android:gravity="end"
                                            app:layout_constraintTop_toTopOf="@+id/mtv_totalcoll_label"
                                            app:layout_constraintBottom_toBottomOf="@+id/mtv_totalcoll_label"
                                            app:layout_constraintEnd_toEndOf="parent"
                                            app:layout_constraintWidth_percent="0.5"/>

                                        <com.google.android.material.textview.MaterialTextView
                                            android:id="@+id/mtv_totaldisblabel"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:text="Total Disbursement:"
                                            android:layout_marginTop="10dp"
                                            app:layout_constraintTop_toBottomOf="@+id/mtv_totalcoll_label"
                                            app:layout_constraintStart_toStartOf="@+id/mtv_totalcoll_label"
                                            app:layout_constraintEnd_toEndOf="@+id/mtv_totalcoll_label"
                                            app:layout_constraintWidth_percent="0.5"/>

                                        <com.google.android.material.textview.MaterialTextView
                                            style="@style/Text_Header"
                                            android:id="@+id/mtv_totaldisb"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:text="0.00"
                                            android:gravity="end"
                                            app:layout_constraintTop_toTopOf="@+id/mtv_totaldisblabel"
                                            app:layout_constraintBottom_toBottomOf="@+id/mtv_totaldisblabel"
                                            app:layout_constraintEnd_toEndOf="parent"
                                            app:layout_constraintWidth_percent="0.5"/>

                                    </androidx.constraintlayout.widget.ConstraintLayout>

                                </com.google.android.material.card.MaterialCardView>

                                <com.google.android.material.textfield.TextInputLayout
                                    style="@style/CustomDropDownTilStyle"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Select Member">

                                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                        android:id="@+id/auto_lodge_member"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"/>

                                </com.google.android.material.textfield.TextInputLayout>

                                <com.google.android.material.textfield.TextInputLayout
                                    style="@style/TextInputStyle"
                                    android:id="@+id/til_pledge_date"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Promised Date">

                                    <com.google.android.material.textfield.TextInputEditText
                                        style="@style/TextInputStyle.Edittext"
                                        android:id="@+id/tie_pledge_date"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:drawableEnd="@drawable/baseline_edit_calendar_24"
                                        android:focusable="false"
                                        android:clickable="true"/>

                                </com.google.android.material.textfield.TextInputLayout>

                                <com.google.android.material.textfield.TextInputLayout
                                    style="@style/TextInputStyle"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Promised to Pay">

                                    <com.google.android.material.textfield.TextInputEditText
                                        style="@style/TextInputStyle.Edittext"
                                        android:id="@+id/tie_pledge_amount"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="0.00"
                                        android:inputType="numberDecimal"/>

                                </com.google.android.material.textfield.TextInputLayout>

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="(Only if applicable)"
                                    android:layout_margin="5dp"
                                    android:alpha="0.7"/>

                                <com.google.android.material.textfield.TextInputLayout
                                    style="@style/TextInputStyle"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="OR No">

                                    <com.google.android.material.textfield.TextInputEditText
                                        style="@style/TextInputStyle.Edittext"
                                        android:id="@+id/tie_or_no"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:inputType="numberDecimal"
                                        android:maxLength="10"/>

                                </com.google.android.material.textfield.TextInputLayout>

                                <com.google.android.material.textfield.TextInputLayout
                                    style="@style/TextInputStyle"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Contributed">

                                    <com.google.android.material.textfield.TextInputEditText
                                        style="@style/TextInputStyle.Edittext"
                                        android:id="@+id/tie_paid_amount"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="0.00"/>

                                </com.google.android.material.textfield.TextInputLayout>

                                <com.google.android.material.textview.MaterialTextView
                                    android:id="@+id/btn_save_detail"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="SAVE"
                                    android:gravity="end"
                                    android:textColor="?attr/colorPrimary"
                                    android:padding="10dp"
                                    android:visibility="gone"/>

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </ScrollView>

            <LinearLayout
                android:id="@+id/layout_buttons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="13dp"
                app:layout_constraintBottom_toBottomOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Save Project"/>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>